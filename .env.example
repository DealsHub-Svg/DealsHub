# ============================================
# DATABASE CONFIGURATION (Required)
# ============================================
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=deals_hub

# ============================================
# EMAIL SERVICE (Required for sending emails)
# ============================================
# Gmail SMTP Configuration
# Get App Password here: https://myaccount.google.com/apppasswords
# (You must have 2FA enabled on your Gmail account)
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
SMTP_USER=your_email@gmail.com

# ============================================
# GOOGLE MAPS API (Required for geolocation)
# ============================================
# Get your API key: https://console.cloud.google.com/
# Make sure Geocoding API is enabled
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# ============================================
# AUTHENTICATION & SECURITY (Required)
# ============================================
JWT_SECRET=your_secret_key_the_longer_the_better_!@#$%

# ============================================
# APPLE SIGN-IN (Optional - if using Apple auth)
# ============================================
# Get from Apple Developer Account: https://developer.apple.com/
APPLE_TEAM_ID=your_team_id
APPLE_KEY_ID=your_key_id
APPLE_PRIVATE_KEY=your_private_key_content

# ============================================
# BACKEND API URLS (Set on Vercel, not locally)
# ============================================
# Development: Leave empty (uses Vite proxy)
# Production: Set to your Vercel backend URL
VITE_API_BASE_URL=https://dealshub-one.vercel.app
VITE_NGROK_URL=https://your-ngrok-url.ngrok-free.dev

# ============================================
# ENVIRONMENT INDICATOR
# ============================================
NODE_ENV=development
VITE_ENV=development
